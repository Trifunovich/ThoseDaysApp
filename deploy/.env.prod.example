# Copy to .env.prod on the host and fill in real secrets. Do NOT commit the
# real file.
COMPOSE_PROJECT_NAME=thosedays-prod

# Image built from `release` and pushed to GHCR by CI.
APP_IMAGE=ghcr.io/trifunovich/thosedaysapp:prod

# App (SPA + API) reachable on the LAN at this port.
APP_PORT=9124

# Postgres published on the LAN for DBeaver.
DB_HOST_PORT=5434

# Seq log UI on the LAN.
SEQ_PORT=9134

DB_NAME=thosedays
DB_USER=thosedays
DB_PASSWORD=change-me-prod

# Release notifications. Prod emails opted-in users on each new version.
NOTIFY_ON_DEPLOY=true
PUBLIC_BASE_URL=https://app.example.com
SMTP_HOST=smtp.sbb.rs
SMTP_PORT=465
SMTP_USER=trifunovich.aleksandar@sbb.rs
SMTP_FROM=trifunovich.aleksandar@sbb.rs
# Real password goes in .env.prod on the server only — never commit it.
SMTP_PASS=change-me
SMTP_ACCEPT_ALL_CERTS=true
