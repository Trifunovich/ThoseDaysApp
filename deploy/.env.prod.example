# Copy to .env.prod on the host and fill in real secrets. Do NOT commit the
# real file.
COMPOSE_PROJECT_NAME=thosedays-prod

# Image built from `release` and pushed to GHCR by CI.
APP_IMAGE=ghcr.io/trifunovich/thosedaysapp:prod

# App (SPA + API) reachable on the LAN at this port.
APP_PORT=9124

# Postgres published on the LAN for DBeaver.
DB_HOST_PORT=5434

# Seq log UI on the LAN.
SEQ_PORT=9134

DB_NAME=thosedays
DB_USER=thosedays
DB_PASSWORD=change-me-prod

# Release notifications. Prod emails opted-in users on each new version.
# Sender = Gmail SMTP with an app password (requires 2-Step Verification on the
# account). Port 587 -> STARTTLS in the app. SMTP_PASS is the 16-char app
# password, set only in .env.prod on the server — never commit it.
NOTIFY_ON_DEPLOY=true
# Period reminders: email opted-in users before a predicted period (opt-in per
# user in Settings). Requires SMTP below. See docs/period-reminders.md.
NOTIFY_REMINDERS=true
# Prod is served at rosella.bearsoft.duckdns.org (the OIDC redirect + post-logout URIs
# registered in CrimsonRaven point here). Must be HTTPS for browser PKCE.
PUBLIC_BASE_URL=https://rosella.bearsoft.duckdns.org
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-account@gmail.com
SMTP_FROM=your-account@gmail.com
SMTP_PASS=app-password-16-chars
SMTP_ACCEPT_ALL_CERTS=false

# Auth token signing for the local (break-glass) login. REQUIRED in prod: a random
# secret of at least 32 chars (a blank/short value logs everyone out on each restart).
JWT_SIGNING_KEY=change-me-prod-at-least-32-chars-long
JWT_EXPIRY_DAYS=30

# CrimsonRaven SSO (OIDC) — prod uses the SEPARATE prod IdP instance. The Rosella Rhythm
# public/PKCE client (its own org) is registered there with redirect
# https://rosella.bearsoft.duckdns.org/auth/callback. See docs/auth-crimsonraven.md.
OIDC_AUTHORITY=https://raven.bearsoft.duckdns.org
OIDC_CLIENT_ID=378269527349198852
OIDC_AUDIENCE=378269527349198852
