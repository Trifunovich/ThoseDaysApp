# Copy to .env.staging on the host and fill in real secrets. Do NOT commit the
# real file.
COMPOSE_PROJECT_NAME=thosedays-staging

# Image built from `main` and pushed to GHCR by CI.
APP_IMAGE=ghcr.io/trifunovich/thosedaysapp:staging

# App (SPA + API) reachable on the LAN at this port.
APP_PORT=9123

# Postgres published on the LAN for DBeaver.
DB_HOST_PORT=5433

# Seq log UI on the LAN.
SEQ_PORT=9133

DB_NAME=thosedays
DB_USER=thosedays
DB_PASSWORD=change-me-staging

# Release notifications. Staging never emails, so the flag is false and SMTP can
# stay blank here.
NOTIFY_ON_DEPLOY=false
# Period reminders off on staging (and SMTP blank below means the sweep no-ops
# anyway). See docs/period-reminders.md.
NOTIFY_REMINDERS=false
# Staging is served over HTTPS at thosedays-staging.bearsoft.duckdns.org (via the .98 nginx +
# *.bearsoft.duckdns.org wildcard cert → this stack's APP_PORT). HTTPS is REQUIRED for the
# CrimsonRaven SSO redirect (browser PKCE needs a secure context); plain-http LAN would break it.
PUBLIC_BASE_URL=https://thosedays-staging.bearsoft.duckdns.org
SMTP_HOST=
SMTP_PORT=465
SMTP_USER=
SMTP_FROM=
SMTP_PASS=
SMTP_ACCEPT_ALL_CERTS=true

# Auth token signing for the local (break-glass) login. REQUIRED: a random secret of
# at least 32 chars. A blank/short value mints an ephemeral key that logs everyone out
# on each restart. JWT_EXPIRY_DAYS controls how long a local login lasts.
JWT_SIGNING_KEY=change-me-staging-at-least-32-chars-long
JWT_EXPIRY_DAYS=30

# CrimsonRaven SSO (OIDC) — the Rosella Rhythm public/PKCE client (its own org on the staging
# instance). The staging client is shared by local dev (it has localhost:3000 + the staging
# HTTPS redirect). OIDC_CLIENT_ID == OIDC_AUDIENCE. See docs/auth-crimsonraven.md.
OIDC_AUTHORITY=https://raven-staging.bearsoft.duckdns.org
OIDC_CLIENT_ID=378269016482971651
OIDC_AUDIENCE=378269016482971651
